{
    "server": {
        "hooks": {
            "onInit": "isDir^%mindUtils",
            "onTerminate": "isFile^%mindUtils",
            "onError": "isFile^%mindUtils"
        },
        "code": "$ydb_dist/plugin/etc/mind/uApi/so/_mindAppTest.so"
    },
    "client": [
        {
            "name": "soTest",
            "methods": [
                {
                    "name": "shouldReturn1",
                    "entryPoint": "soTest^%mindAppTest",
                    "returns": "int"
                },
                {
                    "name": "onInit",
                    "entryPoint": "onInit^%mindAppTest"
                },
                {
                    "name": "onTerminate",
                    "entryPoint": "onTerminate^%mindAppTest"
                },
                {
                    "name": "onError",
                    "entryPoint": "onError^%mindAppTest"
                }
            ]
        }
    ]
}